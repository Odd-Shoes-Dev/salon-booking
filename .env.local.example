# Neon Database (same DB as the main salon system)
DATABASE_URL=postgresql://...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Root domain for owned-domain salons (change this to rebrand without touching code)
# Booking:  {slug}.ROOT_DOMAIN           e.g. posh.blueoxgroup.eu
# System:   system-{slug}.ROOT_DOMAIN    e.g. system-posh.blueoxgroup.eu
NEXT_PUBLIC_ROOT_DOMAIN=blueoxgroup.eu

# eSMS Africa (optional - SMS notifications)
ESMS_API_KEY=
ESMS_BASE_URL=https://sms.esmsafrica.io

# Main system origin (for CORS if needed)
SYSTEM_ORIGIN=http://localhost:3001
